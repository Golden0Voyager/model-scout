# ModelScout Backend Environment Variables

# Proxy settings (required for overseas providers)
http_proxy=http://127.0.0.1:7897
https_proxy=http://127.0.0.1:7897

# Provider API Keys
# Leave blank if not available — models will show as "未配置" (no_key)
SCNET_API_KEY=
AIHUBMIX_API_KEY=
OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=
SILICONFLOW_API_KEY=
ZHIPUAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
MIMO_TOKEN_PLAN_KEY=    # tp-xxxxx (Token Plan)
MIMO_PAYG_API_KEY=      # sk-xxxxx (Pay-as-you-go)
GEMINI_API_KEY=
SENSENOVA_API_KEY=
ANYROUTER_API_KEY=

# If AnyRouter uses a different base URL, override it:
# ANYROUTER_BASE_URL=https://your-anyrouter-endpoint.com/v1

# Scan interval in minutes (default: 5)
SCAN_INTERVAL_MINUTES=5

# Debug logging
DEBUG=false
